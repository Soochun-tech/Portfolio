# --- Secrets / env ---
.env
*.env.local

# --- Data files (large; do NOT commit raw datasets) ---
data/raw/nyc_taxi/*.parquet
data/raw/nyc_taxi/*.csv
data/raw/olist/*.csv
data/exports/*.csv
data/exports/*.xlsx
!data/**/.gitkeep

# --- Python ---
