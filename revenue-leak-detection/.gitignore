*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Dagster ---
.dagster/
dagster_home/
*.duckdb
*.db
tmp_*

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- Docker volumes (keep config, exclude state) ---
mysql_data/

